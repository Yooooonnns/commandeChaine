<Page x:Class="Yazaki.CommandeChaine.Desktop.Views.ChainDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Détail chaîne">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0" Padding="14" UniformCornerRadius="12" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                    <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                        <Button Content="Start" Click="StartChain_OnClick" Padding="10,6" Margin="0,0,8,0" />
                        <Button Content="Stop" Click="StopChain_OnClick" Padding="10,6" />
                        <TextBlock x:Name="ChainStateText" Opacity="0.8" Margin="10,4,0,0" />
                    </StackPanel>
                    <Border DockPanel.Dock="Right" Background="#0F000000" CornerRadius="999" Padding="10,6" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Vitesse recommandée" Opacity="0.75" Margin="0,0,8,0" />
                            <TextBlock x:Name="RecommendedSpeedText" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </DockPanel>

                <Border Grid.Row="1" CornerRadius="10" Background="#FFF7F7F7" Padding="8">
                    <Canvas x:Name="TwinCanvas" Background="Transparent" />
                </Border>
            </Grid>
        </materialDesign:Card>

        <StackPanel Grid.Column="1" Margin="14,0,0,0">
            <Border x:Name="StandardsWarning" Background="#FFFFF4D6" BorderBrush="#FFF59E0B" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,12" Visibility="Collapsed">
                <TextBlock x:Name="StandardsWarningText" Foreground="#FF92400E" TextWrapping="Wrap" />
            </Border>

            <materialDesign:Card Padding="14" UniformCornerRadius="12" Background="White" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="OF en cours" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <TextBlock x:Name="CurrentFoText" Opacity="0.85" />
                    <TextBlock x:Name="FoProgressText" Opacity="0.85" Margin="0,6,0,0" />
                    <Button Content="Annuler l'OF" Click="CancelFo_OnClick" Padding="10,6" Margin="0,10,0,0" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Padding="14" UniformCornerRadius="12" Background="White" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Postes" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ListBox x:Name="TablesList" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="False" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="Poste {Binding Index}" Opacity="0.7" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Content="Ouvrir" Tag="{Binding}" Click="OpenBoard_OnClick" Padding="10,4" Margin="0,0,6,0" />
                                        <Button Content="Valider câbles" Tag="{Binding}" Click="ValidateCables_OnClick" Padding="10,4" />
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Padding="14" UniformCornerRadius="12" Background="White">
                <StackPanel>
                    <TextBlock Text="Derniers scans" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ListBox x:Name="ScansList" Height="260" BorderThickness="0" />
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </Grid>
</Page>
