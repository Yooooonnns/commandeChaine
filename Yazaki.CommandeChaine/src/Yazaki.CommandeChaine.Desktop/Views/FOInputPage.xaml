<Page x:Class="Yazaki.CommandeChaine.Desktop.Views.FOInputPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="FO">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" Padding="14" UniformCornerRadius="12" Background="White" Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <StackPanel>
                        <TextBlock Text="FO Input" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Load an Excel file (Ref, ProductionTimeMinutes, optional LateFlag/Urgent)" Opacity="0.7" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Load Excel" Click="LoadExcel_OnClick" Padding="12,8" Margin="0,0,8,0" />
                        <Button Content="Generate Sample" Click="GenerateSample_OnClick" Padding="12,8" Margin="0,0,8,0" />
                        <Button Content="Clear" Click="Clear_OnClick" Padding="12,8" />
                    </StackPanel>
                </DockPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="FO" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="FoNameText" Width="180" Margin="0,0,12,0" VerticalContentAlignment="Center" />
                    <TextBlock Text="Chaîne" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="ChainSelect" Width="220" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,12,0" />
                    <Button Content="Assign to Chain" Click="AssignToChain_OnClick" Padding="10,6" Margin="0,0,12,0" />
                    <TextBlock x:Name="RecommendationText" VerticalAlignment="Center" Opacity="0.8" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Mark Urgent" Click="MarkUrgent_OnClick" Padding="10,6" Margin="0,0,8,0" />
                <Button Content="Mark Late" Click="MarkLate_OnClick" Padding="10,6" Margin="0,0,8,0" />
                <Button Content="Unmark Late" Click="UnmarkLate_OnClick" Padding="10,6" Margin="0,0,8,0" />
                <Button Content="Unmark Urgent" Click="UnmarkUrgent_OnClick" Padding="10,6" />
            </StackPanel>

            <DataGrid x:Name="FoGrid" Grid.Row="1" Height="420" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False" SelectionMode="Extended"
                      ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLate}" Value="True">
                                <Setter Property="Background" Value="#FFFFF7D6" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding OrderIndex}" Width="50" IsReadOnly="True" />
                    <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="200" />
                    <DataGridTextColumn Header="Prod Time (min)" Binding="{Binding ProductionTimeMinutes}" Width="140" />
                    <DataGridCheckBoxColumn Header="Urgent" Binding="{Binding IsUrgent}" Width="80" />
                    <DataGridCheckBoxColumn Header="Late" Binding="{Binding IsLate}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        </Grid>
    </ScrollViewer>
</Page>
