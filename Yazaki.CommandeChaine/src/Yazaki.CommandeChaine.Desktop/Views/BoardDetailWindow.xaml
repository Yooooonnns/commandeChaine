<Window x:Class="Yazaki.CommandeChaine.Desktop.Views.BoardDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Poste" Height="520" Width="420" WindowStartupLocation="CenterOwner"
        TextElement.FontSize="14" Background="#FFF5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:Card Padding="14" UniformCornerRadius="12" Background="White" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="TitleText" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="BoardNameText" Width="220" Margin="0,0,8,0" />
                    <Button Content="Renommer" Click="Rename_OnClick" Padding="10,6" />
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="1" Padding="14" UniformCornerRadius="12" Background="White" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Harnais en cours" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock x:Name="HarnessRefText" FontSize="16" />
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="2" Padding="14" UniformCornerRadius="12" Background="White" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Progression" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ProgressBar x:Name="HarnessProgress" Height="18" Minimum="0" Maximum="100" />
                <TextBlock x:Name="ProgressText" Margin="0,6,0,0" Opacity="0.8" />
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="3" Padding="14" UniformCornerRadius="12" Background="White" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Progression cible" FontWeight="SemiBold" Margin="0,0,0,6" />
                <UniformGrid x:Name="WorkBandGrid" Columns="20" Rows="1" Height="16" Margin="0,0,0,0" />
                <Canvas x:Name="ArrowCanvas" Height="14" Margin="0,0,0,4" ClipToBounds="True">
                    <TextBlock x:Name="ArrowIndicator" Text="▶" FontSize="12" Foreground="#333" Canvas.Top="0" Canvas.Left="0" />
                </Canvas>
                <TextBlock x:Name="WorkBandText" Opacity="0.8" />
                <TextBlock x:Name="WorkBandLateText" FontWeight="SemiBold" />
                <TextBlock x:Name="CreditText" Opacity="0.8" Margin="0,4,0,0" />
                <TextBlock x:Name="CreditTrendText" FontWeight="SemiBold" />
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="4" Padding="14" UniformCornerRadius="12" Background="White">
            <StackPanel>
                <TextBlock Text="Historique des arrets" FontWeight="SemiBold" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Cause" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="StopCauseSelect" Width="160" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="StopButton" Content="Stop" Click="Stop_OnClick" Padding="10,6" Margin="0,0,8,0" />
                    <Button x:Name="ResumeButton" Content="Reprendre" Click="Resume_OnClick" Padding="10,6" IsEnabled="False" />
                </StackPanel>
                <TextBlock x:Name="StopStateText" Opacity="0.8" Margin="0,0,0,6" />
                <ListBox x:Name="StopsList" BorderThickness="0" />
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
