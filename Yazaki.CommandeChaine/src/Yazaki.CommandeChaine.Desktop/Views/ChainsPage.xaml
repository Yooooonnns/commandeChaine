<Page x:Class="Yazaki.CommandeChaine.Desktop.Views.ChainsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Chaînes">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14" LastChildFill="False">
            <TextBlock Text="Gestion des chaînes" FontSize="22" FontWeight="SemiBold" />
            <Button DockPanel.Dock="Right" Content="Rafraîchir" Click="Refresh_OnClick" Padding="12,8" />
        </DockPanel>

        <materialDesign:Card Grid.Row="1" Padding="14" UniformCornerRadius="14" Margin="0,0,0,14" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Créer une nouvelle chaîne" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <DockPanel LastChildFill="True">
                        <TextBox x:Name="NewChainName" MinWidth="320" Height="34" VerticalContentAlignment="Center"
                                 materialDesign:HintAssist.Hint="Nom de la chaîne (ex: Ligne 1)" />
                        <TextBox x:Name="NewTableCount" Width="110" Height="34" Margin="10,0,0,0"
                                 VerticalContentAlignment="Center"
                                 materialDesign:HintAssist.Hint="Nb tableaux" ToolTip="Optionnel. Mettre 0 pour créer sans tableaux." />
                    </DockPanel>
                </StackPanel>

                <Button Grid.Column="1" Content="Créer" Click="CreateChain_OnClick" Padding="14,10" Margin="0,0,10,0" VerticalAlignment="Center" />
                <Button Grid.Column="2" Content="Créer + ouvrir" Click="CreateAndOpen_OnClick" Padding="14,10" VerticalAlignment="Center" />
            </Grid>
        </materialDesign:Card>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ChainsItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" ItemWidth="420" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Padding="14" UniformCornerRadius="14" Background="White" Margin="0,0,14,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding TableCount, StringFormat={}{0} tableaux}" Opacity="0.7" />
                                    </StackPanel>

                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Ouvrir" Click="OpenChain_OnClick" Tag="{Binding Chain}" Padding="12,6" Margin="0,0,8,0" />
                                        <Button Content="Supprimer" Click="DeleteChain_OnClick" Tag="{Binding Id}" Padding="12,6" />
                                    </StackPanel>
                                </DockPanel>

                                <StackPanel Grid.Row="1">
                                    <TextBox Text="{Binding Name}" Tag="{Binding Id}" Height="34" VerticalContentAlignment="Center"
                                             materialDesign:HintAssist.Hint="Renommer (Entrée pour valider)" KeyDown="Rename_OnKeyDown" />
                                    <TextBox Text="{Binding TableCount}" Tag="{Binding Id}" Height="34" Margin="0,8,0,0" VerticalContentAlignment="Center"
                                             materialDesign:HintAssist.Hint="Modifier nb tableaux (Entrée pour valider)" KeyDown="TableCount_OnKeyDown" />
                                </StackPanel>
                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
