# Application settings
RASPI_HOST=0.0.0.0
RASPI_PORT=8000

# Data paths (optional)
# RASPI_DB_PATH=./data/raspberry.db
# RASPI_LOG_PATH=./data/raspberry.log

# Speed and voltage ranges
RASPI_SPEED_MIN=20.0
RASPI_SPEED_MAX=80.0
RASPI_DEFAULT_SPEED=50.0
RASPI_VOLTAGE_MIN=0.0
RASPI_VOLTAGE_MAX=10.0

# Control tuning
RASPI_RAMP_RATE_V_PER_SEC=1.0
RASPI_MAX_TIMESTAMP_AGE_SEC=30
